{
  "name": "scope-v2",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @scope/desktop dev",
    "dev:ext": "pnpm --filter @scope/extension dev",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @scope/desktop build",
    "build:extension": "pnpm --filter @scope/extension build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
